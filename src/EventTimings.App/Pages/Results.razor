@page "/results"
@inject EventTimingApiClient ApiClient
@inject IJSRuntime JsRuntime
@inject EventTimings.App.Services.CredentialState credentialState
@using EventTimings.Contracts

<PageTitle>Results</PageTitle>

<section class="panel">
    <h1>Finished times report</h1>
    <p class="muted">View current rider results and export the full report to CSV.</p>

    <div class="action-row">
        <button class="secondary-action" type="button" @onclick="LoadAsync" disabled="@isLoading">Refresh</button>
        <button class="primary-action" type="button" @onclick="ExportCsvAsync" disabled="@isExporting">Export CSV</button>
        @if (credentialState.IsAuthenticated)
        {
            <button class="secondary-action" type="button" @onclick="ShowResetModal" disabled="@isResetting">Reset</button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p class="muted">@statusMessage</p>
    }
</section>

<section class="panel">
    <h2>Rider results</h2>
    <p class="muted">@finishedCount of @rows.Count riders finished.</p>

    @if (rows.Count == 0)
    {
        <p class="muted">No riders found.</p>
    }
    else
    {
        <div class="results-table-wrapper">
            <table class="results-table">
                <thead>
                    <tr>
                        <th>Bib</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Route</th>
                        <th>Started</th>
                        <th>Finished</th>
                        <th>Elapsed</th>
                        <th>Status</th>
                        <th class="actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@row.BibNumber</td>
                            <td>@row.FullName</td>
                            <td>@row.Category</td>
                            <td>@(row.RouteName ?? "-")</td>
                            <td>@FormatDateTime(row.StartedAt)</td>
                            <td>@FormatDateTime(row.FinishedAt)</td>
                            <td>@FormatElapsed(row.ElapsedSeconds)</td>
                            <td>@row.Status</td>
                            <td class="actions-col">
                                @if (row.Status == "Finished")
                                {
                                    if (adjustingRiderIds.Contains(row.RiderId))
                                    {
                                        <span class="muted">Updating…</span>
                                    }
                                    else if (!credentialState.IsAuthenticated)
                                    {
                                        <span class="muted">Sign in to adjust</span>
                                    }
                                    else
                                    {
                                        <div style="display:flex; align-items:center;">
                                            <button class="secondary-action tiny-action" type="button" @onclick="MakeAdjuster(row.RiderId, -1)">-1m</button>
                                            <button class="secondary-action tiny-action" type="button" @onclick="MakeAdjuster(row.RiderId, 1)">+1m</button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private List<FinishedTimeReportRowDto> rows = [];
    private string? statusMessage;
    private bool isLoading;
    private bool isExporting;
    private bool showResetModal;
    private string resetPin = string.Empty;
    private bool isResetting;
    private string? resetStatusMessage;

    private int finishedCount => rows.Count(row => row.Status == "Finished");

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        statusMessage = null;

        try
        {
            rows = (await ApiClient.GetFinishedTimeReportAsync())?
                .OrderBy(row => row.Status != "Finished")
                .ThenBy(row => row.ElapsedSeconds ?? long.MaxValue)
                .ThenBy(row => row.FullName)
                .ToList()
                ?? [];

            statusMessage = $"Loaded {rows.Count} rider result(s).";
        }
        catch
        {
            statusMessage = "Unable to load results. Check the API and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExportCsvAsync()
    {
        isExporting = true;
        statusMessage = null;

        try
        {
            var csv = await ApiClient.GetFinishedTimesCsvAsync();
            if (string.IsNullOrWhiteSpace(csv))
            {
                statusMessage = "No CSV data available yet.";
                return;
            }

            await JsRuntime.InvokeVoidAsync("downloadFileFromText", "finished-times-report.csv", csv);
            statusMessage = "CSV export downloaded.";
        }
        catch
        {
            statusMessage = "Unable to export CSV. Check the API and try again.";
        }
        finally
        {
            isExporting = false;
        }
    }

    private static string FormatDateTime(DateTimeOffset? value)
    {
        return value?.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? "-";
    }

    private static string FormatElapsed(long? elapsedSeconds)
    {
        return elapsedSeconds is null
            ? "-"
            : TimeSpan.FromSeconds(elapsedSeconds.Value).ToString(@"hh\:mm\:ss");
    }

    private void ShowResetModal()
    {
        resetPin = string.Empty;
        resetStatusMessage = null;
        showResetModal = true;
    }

    private void CloseResetModal()
    {
        showResetModal = false;
        resetPin = string.Empty;
        resetStatusMessage = null;
    }

    private async Task ConfirmResetAsync()
    {
        isResetting = true;
        resetStatusMessage = null;

        try
        {
            // re-verify PIN
            var verify = await ApiClient.VerifyOfficialAsync(new OfficialVerificationRequest(credentialState.OfficialName, resetPin));
            if (verify is null || !verify.Success)
            {
                resetStatusMessage = verify?.Message ?? "Verification failed.";
                return;
            }

            var currentEvent = await ApiClient.GetCurrentEventAsync();
            var eventCode = currentEvent?.EventCode ?? string.Empty;

            var req = new TimingCommandRequest(eventCode, credentialState.OfficialName, resetPin, string.Empty);
            var result = await ApiClient.ResetTimingsAsync(req);
            if (result is not null && result.Success)
            {
                showResetModal = false;
                await LoadAsync();
                statusMessage = result.Message;
            }
            else
            {
                resetStatusMessage = result?.Message ?? "Reset failed.";
            }
        }
        catch
        {
            resetStatusMessage = "Reset failed — API not reachable.";
        }
        finally
        {
            isResetting = false;
        }
    }

    private Func<Task> MakeAdjuster(string riderId, int delta) => () => AdjustFinishedTimeAsync(riderId, delta);

    private HashSet<string> adjustingRiderIds = new();

    private async Task AdjustFinishedTimeAsync(string riderId, int deltaMinutes)
    {
        if (!credentialState.IsAuthenticated)
        {
            statusMessage = "Sign in as an official to adjust timings.";
            return;
        }

        if (string.IsNullOrWhiteSpace(credentialState.Pin))
        {
            statusMessage = "Please re-enter your PIN in the sign-in modal before adjusting times.";
            return;
        }

        adjustingRiderIds.Add(riderId);
        try
        {
            var currentEvent = await ApiClient.GetCurrentEventAsync();
            var eventCode = currentEvent?.EventCode ?? string.Empty;
            var req = new AdjustTimingRequest(eventCode, credentialState.OfficialName, credentialState.Pin, riderId, deltaMinutes);
            try { await JsRuntime.InvokeVoidAsync("console.log", "AdjustFinishedTime:request", req); } catch { }
            var result = await ApiClient.AdjustTimingAsync(req);
            try { await JsRuntime.InvokeVoidAsync("console.log", "AdjustFinishedTime:result", result); } catch { }
            if (result is not null)
            {
                if (result.Success)
                {
                    await LoadAsync();
                    statusMessage = result.Message;
                }
                else
                {
                    statusMessage = result.Message;
                }
            }
            else
            {
                statusMessage = "Adjust failed. Check the API and try again.";
            }
        }
        catch (Exception ex)
        {
            try { await JsRuntime.InvokeVoidAsync("console.error", "AdjustFinishedTime:error", ex.ToString()); } catch { }
            statusMessage = "Unable to adjust — API not reachable.";
        }
        finally
        {
            adjustingRiderIds.Remove(riderId);
            await InvokeAsync(StateHasChanged);
        }
    }
}

@* Reset PIN modal *@
@if (showResetModal)
{
    <div class="modal-backdrop">
        <div class="modal-dialog modal-centered">
            <div class="panel">
                <h3>Confirm reset</h3>
                <p class="muted">This will clear all recorded start and stop times for the event. Participants will not be deleted.</p>

                <div class="form-grid">
                    <label>
                        <span>Enter PIN to confirm</span>
                        <input @bind="resetPin" inputmode="numeric" type="password" maxlength="4" />
                    </label>
                </div>

                @if (!string.IsNullOrWhiteSpace(resetStatusMessage))
                {
                    <p class="muted">@resetStatusMessage</p>
                }

                <div class="action-row">
                    <button class="secondary-action" @onclick="CloseResetModal" disabled="@isResetting">Cancel</button>
                    <button class="primary-action" @onclick="ConfirmResetAsync" disabled="@(isResetting || string.IsNullOrWhiteSpace(resetPin))">Confirm reset</button>
                </div>
            </div>
        </div>
    </div>

    <style>
        .modal-backdrop { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.5); z-index: 100000; pointer-events: auto; }
        .modal-dialog.modal-centered { max-width: 420px; width: 100%; z-index: 100001; pointer-events: auto; }
        .modal-dialog .panel { padding: 1rem; pointer-events: auto; }
        .modal-backdrop .modal-dialog * { pointer-events: auto; }
    </style>
}
